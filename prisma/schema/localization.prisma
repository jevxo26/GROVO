model Footer {
  id          String       @id @default(uuid())
  content     String?
  copyright   String?
  status      String       @default("ACTIVE")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  socialLinks SocialLink[]
}

model SocialLink {
  id        String   @id @default(uuid())
  footerId  String?
  footer    Footer?  @relation(fields: [footerId], references: [id], onDelete: SetNull)
  platform  String
  url       String
  icon      String?
  sortOrder Int      @default(0)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactInformation {
  id           String   @id @default(uuid())
  organization String
  email        String
  phone        String
  address      String?
  mapUrl       String?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OfficeLocation {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String?
  email     String?
  latitude  Float?
  longitude Float?
  isHead    Boolean  @default(false)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SEOSetting {
  id              String   @id @default(uuid())
  pageUrl         String   @unique
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  canonicalUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Language {
  id           String        @id @default(uuid())
  languageCode String        @unique
  languageName String
  isDefault    Boolean       @default(false)
  isRtl        Boolean       @default(false)
  status       String        @default("ACTIVE")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  translations Translation[]
}

model Translation {
  id         String   @id @default(uuid())
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  key        String
  value      String
  module     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([languageId, key])
}

model Currency {
  id           String   @id @default(uuid())
  currencyCode String   @unique
  currencyName String
  symbol       String
  exchangeRate Float    @default(1)
  isDefault    Boolean  @default(false)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
