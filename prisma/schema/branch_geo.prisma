model Region {
  id          String   @id @default(uuid())
  regionName  String
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ward {
  id         String   @id @default(uuid())
  wardName   String
  wardNumber Int
  unionId    String?
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AreaCoverage {
  id         String   @id @default(uuid())
  branchId   String
  divisionId String?
  districtId String?
  upazilaId  String?
  unionId    String?
  population Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model BranchCoverage {
  id               String   @id @default(uuid())
  branchId         String
  branch           Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  coverageArea     String
  populationServed Int      @default(0)
  activeSince      DateTime?
  status           String   @default("ACTIVE")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model OperationalZone {
  id               String           @id @default(uuid())
  zoneName         String
  description      String?
  status           String           @default("ACTIVE")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  zoneAssignments  ZoneAssignment[]
}

model ZoneAssignment {
  id             String          @id @default(uuid())
  zoneId         String
  zone           OperationalZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignedDate   DateTime        @default(now())
  status         String          @default("ACTIVE")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}
