model UserDevice {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId        String
  deviceName      String?
  deviceType      String?
  operatingSystem String?
  browser         String?
  appVersion      String?
  ipAddress       String?
  lastLogin       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserSession {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId     String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  loginTime    DateTime  @default(now())
  logoutTime   DateTime?
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now())
}

model UserToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  tokenType String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model UserOTP {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone      String?
  otp        String
  purpose    String
  expiresAt  DateTime
  verifiedAt DateTime?
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now())
}

model UserLoginHistory {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId   String?
  ipAddress  String?
  location   String?
  loginTime  DateTime  @default(now())
  logoutTime DateTime?
  status     String    @default("SUCCESS")
  createdAt  DateTime  @default(now())
}
