model SmartDonationRecommendation {
  id               String   @id @default(uuid())
  donorId          String
  campaignId       String?
  recommendedAmount Float?
  reason           String?
  confidenceScore  Float    @default(0)
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
}

model SmartCampaignRecommendation {
  id              String   @id @default(uuid())
  campaignId      String
  recommendation  String
  targetAudience  String?
  expectedImpact  Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}

model SmartVolunteerRecommendation {
  id              String   @id @default(uuid())
  volunteerId     String
  projectId       String?
  campaignId      String?
  matchScore      Float    @default(0)
  reason          String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}

model SmartBeneficiaryMatching {
  id              String   @id @default(uuid())
  beneficiaryId   String
  campaignId      String?
  projectId       String?
  matchScore      Float    @default(0)
  matchReason     String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}

model SmartProjectRecommendation {
  id              String   @id @default(uuid())
  branchId        String
  projectType     String
  recommendation  String
  expectedImpact  Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}
