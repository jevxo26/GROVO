model SuperAdmin {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions String[]
  assignedBy  String
  assignedAt  DateTime @default(now())
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserPermission {
  id           String   @id @default(uuid())
  userId       String
  module       String
  action       String
  isAllowed    Boolean  @default(true)
  grantedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AccessPolicy {
  id          String   @id @default(uuid())
  policyName  String   @unique
  description String?
  rules       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model APIAccessPermission {
  id          String   @id @default(uuid())
  roleId      String?
  userId      String?
  endpoint    String
  method      String
  isAllowed   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IPWhitelist {
  id          String   @id @default(uuid())
  ipAddress   String
  description String?
  addedBy     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IPBlacklist {
  id          String   @id @default(uuid())
  ipAddress   String
  reason      String?
  blockedBy   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
