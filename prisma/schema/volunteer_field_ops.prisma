model FieldActivity {
  id            String           @id @default(uuid())
  projectId     String
  activityTitle String
  activityType  String
  location      String?
  description   String?
  performedBy   String
  activityDate  DateTime
  status        String           @default("ACTIVE")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  visits        FieldVisit[]
  reports       ActivityReport[]
}

model FieldVisit {
  id         String        @id @default(uuid())
  activityId String
  activity   FieldActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  visitedBy  String
  divisionId String?
  districtId String?
  upazilaId  String?
  unionId    String?
  visitDate  DateTime
  remarks    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model ActivityReport {
  id                 String        @id @default(uuid())
  activityId         String
  activity           FieldActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  reportTitle        String
  summary            String?
  beneficiariesCount Int           @default(0)
  totalExpense       Float
  reportFile         String?
  submittedBy        String
  approvedBy         String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model BeneficiaryVerification {
  id                 String   @id @default(uuid())
  beneficiaryId      String
  verifiedBy         String
  verificationMethod String
  verificationStatus String   @default("VERIFIED")
  remarks            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
