model BranchInventory {
  id          String   @id @default(uuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  itemName    String
  quantity    Int      @default(0)
  unit        String
  location    String?
  status      String   @default("AVAILABLE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BranchVehicle {
  id              String   @id @default(uuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  vehicleNumber   String
  vehicleType     String
  assignedDriver  String?
  status          String   @default("AVAILABLE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BranchMeeting {
  id           String   @id @default(uuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title        String
  agenda       String?
  meetingDate  DateTime
  location     String?
  attendees    String[]
  minutes      String?
  status       String   @default("SCHEDULED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BranchAnnouncement {
  id          String   @id @default(uuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title       String
  content     String
  publishedBy String
  expiresAt   DateTime?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BranchDocument {
  id           String   @id @default(uuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  documentName String
  documentType String
  fileUrl      String
  uploadedBy   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
