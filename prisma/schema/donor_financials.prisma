model DonorSubscription {
  id              String    @id @default(uuid())
  donorId         String
  donor           Donor     @relation(fields: [donorId], references: [id], onDelete: Cascade)
  subscriptionType String
  amount          Float
  billingCycle    String
  startDate       DateTime  @default(now())
  nextBillingDate DateTime?
  endDate         DateTime?
  autoRenew       Boolean   @default(true)
  status          String    @default("ACTIVE")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model DonationCommitment {
  id              String    @id @default(uuid())
  donorId         String
  donor           Donor     @relation(fields: [donorId], references: [id], onDelete: Cascade)
  campaignId      String?
  pledgedAmount   Float
  paidAmount      Float     @default(0)
  remainingAmount Float
  dueDate         DateTime?
  status          String    @default("PENDING")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model DonorWallet {
  id           String             @id @default(uuid())
  donorId      String             @unique
  donor        Donor              @relation(fields: [donorId], references: [id], onDelete: Cascade)
  balance      Float              @default(0)
  totalDonated Float              @default(0)
  rewardPoints Int                @default(0)
  status       String             @default("ACTIVE")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  transactions DonorTransaction[]
}

model DonorTransaction {
  id              String      @id @default(uuid())
  walletId        String
  wallet          DonorWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transactionType String
  amount          Float
  referenceNo     String?
  description     String?
  status          String      @default("SUCCESS")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
