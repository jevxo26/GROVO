model AnalyticsSnapshot {
  id           String   @id @default(uuid())
  snapshotType String
  period       String
  data         String
  generatedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
}

model DonationAnalytics {
  id             String   @id @default(uuid())
  period         String
  totalDonations Float    @default(0)
  donorCount     Int      @default(0)
  avgDonation    Float    @default(0)
  topCampaign    String?
  growthRate     Float    @default(0)
  createdAt      DateTime @default(now())
}

model CampaignAnalytics {
  id                String   @id @default(uuid())
  campaignId        String
  totalRaised       Float    @default(0)
  donorCount        Int      @default(0)
  goalProgress      Float    @default(0)
  avgDonation       Float    @default(0)
  conversionRate    Float    @default(0)
  createdAt         DateTime @default(now())
}

model ProjectAnalytics {
  id                   String   @id @default(uuid())
  projectId            String
  totalExpense         Float    @default(0)
  beneficiariesReached Int      @default(0)
  completionRate       Float    @default(0)
  volunteerHours       Float    @default(0)
  createdAt            DateTime @default(now())
}

model VolunteerAnalytics {
  id                String   @id @default(uuid())
  period            String
  totalVolunteers   Int      @default(0)
  activeVolunteers  Int      @default(0)
  totalHoursLogged  Float    @default(0)
  avgAttendanceRate Float    @default(0)
  createdAt         DateTime @default(now())
}

model BeneficiaryAnalytics {
  id                    String   @id @default(uuid())
  period                String
  totalBeneficiaries    Int      @default(0)
  newBeneficiaries      Int      @default(0)
  totalDistributions    Int      @default(0)
  totalDistributedValue Float    @default(0)
  createdAt             DateTime @default(now())
}

model BranchAnalytics {
  id              String   @id @default(uuid())
  branchId        String
  period          String
  totalDonations  Float    @default(0)
  totalExpenses   Float    @default(0)
  volunteerCount  Int      @default(0)
  projectCount    Int      @default(0)
  createdAt       DateTime @default(now())
}

model FinancialAnalytics {
  id            String   @id @default(uuid())
  period        String
  totalIncome   Float    @default(0)
  totalExpense  Float    @default(0)
  netBalance    Float    @default(0)
  growthRate    Float    @default(0)
  createdAt     DateTime @default(now())
}

model MembershipAnalytics {
  id               String   @id @default(uuid())
  period           String
  totalMembers     Int      @default(0)
  newMembers       Int      @default(0)
  renewalRate      Float    @default(0)
  totalContribution Float   @default(0)
  createdAt        DateTime @default(now())
}

model UserActivityAnalytics {
  id              String   @id @default(uuid())
  period          String
  totalLogins     Int      @default(0)
  activeUsers     Int      @default(0)
  avgSessionTime  Float    @default(0)
  createdAt       DateTime @default(now())
}

model VisitorAnalytics {
  id            String   @id @default(uuid())
  pageUrl       String
  visitorCount  Int      @default(0)
  uniqueVisitors Int     @default(0)
  bounceRate    Float    @default(0)
  avgTimeOnPage Float    @default(0)
  date          DateTime
  createdAt     DateTime @default(now())
}

model PerformanceMetric {
  id          String   @id @default(uuid())
  metricName  String
  category    String
  value       Float
  unit        String?
  measuredAt  DateTime @default(now())
  createdAt   DateTime @default(now())
}
