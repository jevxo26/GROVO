enum MembershipType {
  INDIVIDUAL
  CORPORATE
  LIFETIME
  ANNUAL
  MONTHLY
  HONORARY
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  EXPIRED
  SUSPENDED
  REACTIVATED
}


model Membership {
  id                  String    @id @default(cuid())
  userId              String    
  membershipNumber    String    @unique
  membershipType      MembershipType @default(MONTHLY)
  organizationRole    String?
  joiningDate         DateTime
  expiryDate          DateTime?
  monthlyContribution Float?
  status              MembershipStatus    @default(PENDING)
  approvedBy          String?
  approvedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards         MembershipCard[]
  verifications MembershipVerification[]
  renewals      MembershipRenewal[]
  activities    MembershipActivity[]
}

enum CardType {
  PHYSICAL
  DIGITAL
  BOTH
}

enum CardStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  EXPIRED
  PENDING
}
model MembershipCard {
  id           String    @id @default(cuid())
  membershipId String
  cardNumber   String    @unique
  cardType     CardType @default(DIGITAL)
  issueDate    DateTime
  expiryDate   DateTime?
  cardStatus   CardStatus    @default(ACTIVE)
  profilePhoto String?
  signature    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  membership Membership         @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  qrCodes    MembershipQRCode[]
}

model MembershipQRCode {
  id               String    @id @default(cuid())
  membershipCardId String
  qrCode           String
  barcode          String?
  verificationUrl  String?
  scanCount        Int       @default(0)
  lastScannedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  membershipCard MembershipCard @relation(fields: [membershipCardId], references: [id], onDelete: Cascade)
}

enum VerificationMethod {
  EMAIL
  PHONE
  QR_CODE
  MANUAL
  BIOMETRIC
  DOCUMENT
  MANUAL_VERIFICATION  // <-- Add this value
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  FAILED
}

model MembershipVerification {
  id                 String    @id @default(cuid())
  membershipId       String
  verificationMethod  VerificationMethod?
  verifiedBy         String?
  verificationStatus  VerificationStatus @default(PENDING)
  verificationDate   DateTime?
  remarks            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIAL
}


model MembershipRenewal {
  id             String    @id @default(cuid())
  membershipId   String
  renewalDate    DateTime
  renewalAmount  Float?
  paymentStatus  PaymentStatus @default(PENDING)
  nextExpiryDate DateTime?
  processedBy    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
}

enum MembershipActivityType {
  REGISTRATION
  MEMBERSHIP_APPROVED
  MEMBERSHIP_REJECTED
  CARD_GENERATED
  QR_GENERATED
  QR_VERIFIED
  MEMBERSHIP_RENEWED
  MEMBERSHIP_SUSPENDED
  MEMBERSHIP_EXPIRED
  MEMBERSHIP_REACTIVATED
  MEMBERSHIP_UPDATED
  MEMBERSHIP_CANCELLED
}

model MembershipActivity {
  id           String   @id @default(cuid())
  membershipId String
  activityType MembershipActivityType? 
  description  String?
  performedBy  String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
}
