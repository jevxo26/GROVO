model Membership {
  id                  String    @id @default(cuid())
  userId              String
  membershipNumber    String    @unique
  membershipType      String // Enum: Volunteer, General Member, Individual Donor, Corporate Donor, Staff, Executive Member, Coordinator
  organizationRole    String?
  joiningDate         DateTime
  expiryDate          DateTime?
  monthlyContribution Float?
  status              String    @default("PENDING")
  approvedBy          String?
  approvedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards         MembershipCard[]
  verifications MembershipVerification[]
  renewals      MembershipRenewal[]
  activities    MembershipActivity[]
}

model MembershipCard {
  id           String    @id @default(cuid())
  membershipId String
  cardNumber   String    @unique
  cardType     String
  issueDate    DateTime
  expiryDate   DateTime?
  cardStatus   String    @default("ACTIVE")
  profilePhoto String?
  signature    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  membership Membership         @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  qrCodes    MembershipQRCode[]
}

model MembershipQRCode {
  id               String    @id @default(cuid())
  membershipCardId String
  qrCode           String
  barcode          String?
  verificationUrl  String?
  scanCount        Int       @default(0)
  lastScannedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  membershipCard MembershipCard @relation(fields: [membershipCardId], references: [id], onDelete: Cascade)
}

model MembershipVerification {
  id                 String    @id @default(cuid())
  membershipId       String
  verificationMethod String
  verifiedBy         String?
  verificationStatus String
  verificationDate   DateTime?
  remarks            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
}

model MembershipRenewal {
  id             String    @id @default(cuid())
  membershipId   String
  renewalDate    DateTime
  renewalAmount  Float?
  paymentStatus  String    @default("PENDING")
  nextExpiryDate DateTime?
  processedBy    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
}

model MembershipActivity {
  id           String   @id @default(cuid())
  membershipId String
  activityType String // Enum: Registration, Membership Approved, Membership Rejected, Card Generated, QR Generated, QR Verified, Membership Renewed, Membership Suspended, Membership Expired, Membership Reactivated
  description  String?
  performedBy  String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
}
