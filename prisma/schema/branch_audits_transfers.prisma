model BranchAudit {
  id          String    @id @default(uuid())
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  auditType   String
  auditor     String
  findings    String?
  auditDate   DateTime
  resolvedAt  DateTime?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BranchTransfer {
  id             String   @id @default(uuid())
  fromBranchId   String
  fromBranch     Branch   @relation("TransferFrom", fields: [fromBranchId], references: [id], onDelete: Cascade)
  toBranchId     String
  toBranch       Branch   @relation("TransferTo", fields: [toBranchId], references: [id], onDelete: Cascade)
  transferType   String
  description    String?
  approvedBy     String?
  transferDate   DateTime @default(now())
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BranchStatistics {
  id             String   @id @default(uuid())
  branchId       String
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  period         String
  memberCount    Int      @default(0)
  donationTotal  Float    @default(0)
  projectCount   Int      @default(0)
  volunteerCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BranchDashboard {
  id          String   @id @default(uuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  widgetType  String
  config      String?
  sortOrder   Int      @default(0)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BranchActivityLog {
  id          String   @id @default(uuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  activity    String
  performedBy String
  details     String?
  createdAt   DateTime @default(now())
}

model OrganizationActivityLog {
  id             String   @id @default(uuid())
  organizationId String
  activity       String
  performedBy    String
  details        String?
  createdAt      DateTime @default(now())
}

model OrganizationProfile {
  id             String   @id @default(uuid())
  organizationId String
  mission        String?
  vision         String?
  history        String?
  coreValues     String?
  socialLinks    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
