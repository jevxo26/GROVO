

enum bloodGroup {
  A_Positive
  A_Negative
  B_Positive
  B_Negative
  AB_Positive
  AB_Negative
  O_Positive
  O_Negative
}


// ==========================================
// 1. User
// ==========================================
model User {
  id            String      @id @default(cuid())
  firstName     String?
  lastName      String?
  fullName      String?
  email         String      @unique
  phone         String?
  password      String?
  profilePhoto  String?
  dateOfBirth   DateTime?
  gender        Gender?
  bloodGroup    BloodGroup?
  nationalId    String?
  status        UserStatus  @default(PENDING)
  isVerified    Boolean     @default(false)
  lastLogin     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  role          UserRole    @default(GENERAL_MEMBER)

  userProfile         UserProfile?
  devices             UserDevice[]
  userSessions        UserSession[]
  tokens              UserToken[]
  otps                UserOTP[]
  loginHistory        UserLoginHistory[]
  notificationSetting UserNotificationSetting?
  security            UserSecurity?
  addresses           UserAddress[]
  membership          Membership[]

  createdCampaigns   Campaign[]         @relation("CampaignCreator")
  campaignDonations  CampaignDonation[] @relation("CampaignDonations")
  managedProjects    Project[]          @relation("ProjectManager")
  projectVolunteers  ProjectVolunteer[] @relation("ProjectVolunteers")

  @@map("user")
}

// ==========================================
// 2. UserProfile
// ==========================================
model UserProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  fatherName   String?
  motherName   String?
  occupation   String?
  organization String?
  designation  String?
  education    String?
  bio          String?
  facebook     String?
  linkedin     String?
  website      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 3. UserDevice
// ==========================================
model UserDevice {
  id              String    @id @default(cuid())
  userId          String
  deviceId        String?   @unique
  deviceName      String?
  deviceType      String?
  operatingSystem String?
  browser         String?
  appVersion      String?
  ipAddress       String?
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 4. UserSession
// ==========================================
model UserSession {
  id           String        @id @default(cuid())
  userId       String
  deviceId     String?
  accessToken  String        @unique
  refreshToken String?       @unique
  expiresAt    DateTime
  loginTime    DateTime      @default(now())
  logoutTime   DateTime?
  status       SessionStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 5. UserToken
// ==========================================
model UserToken {
  id        String         @id @default(cuid())
  userId    String
  token     String         @unique
  tokenType UserTokenType?
  expiresAt DateTime
  isUsed    Boolean        @default(false)
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 6. UserOTP
// ==========================================
model UserOTP {
  id         String      @id @default(cuid())
  userId     String
  phone      String
  otp        String
  purpose    OTPPurpose?
  expiresAt  DateTime
  verifiedAt DateTime?
  status     OTPStatus   @default(PENDING)
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 7. UserLoginHistory
// ==========================================
model UserLoginHistory {
  id         String      @id @default(cuid())
  userId     String
  deviceId   String?
  ipAddress  String?
  location   String?
  loginTime  DateTime    @default(now())
  logoutTime DateTime?
  status     LoginStatus @default(SUCCESS)
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 8. UserNotificationSetting
// ==========================================
model UserNotificationSetting {
  id                    String   @id @default(cuid())
  userId                String   @unique
  pushNotification      Boolean  @default(true)
  emailNotification     Boolean  @default(true)
  smsNotification       Boolean  @default(true)
  campaignNotification  Boolean  @default(true)
  emergencyNotification Boolean  @default(true)
  newsletter            Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 9. UserSecurity
// ==========================================
model UserSecurity {
  id                  String    @id @default(cuid())
  userId              String    @unique
  twoFactorEnabled    Boolean   @default(false)
  securityQuestion    String?
  securityAnswer      String?
  failedLoginAttempts Int       @default(0)
  accountLocked       Boolean   @default(false)
  lastPasswordChanged DateTime? @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 10. UserAddress
// ==========================================
model UserAddress {
  id          String   @id @default(cuid())
  userId      String
  countryId   String?
  divisionId  String?
  districtId  String?
  upazilaId   String?
  unionId     String?
  village     String?
  postCode    String?
  addressLine String?
  latitude    Float?
  longitude   Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
