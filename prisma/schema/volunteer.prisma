model Volunteer {
  id                String                  @id @default(uuid())
  userId            String                  @unique
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  volunteerCode     String                  @unique
  branchId          String
  branch            Branch                  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  membershipId      String?
  joiningDate       DateTime                @default(now())
  experience        String?
  status            String                  @default("ACTIVE")
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  profile           VolunteerProfile?
  skills            VolunteerSkill[]
  availabilities    VolunteerAvailability[]
  performances      VolunteerPerformance[]
  rewards           VolunteerReward[]
  certificates      VolunteerCertificate[]
  expenses          VolunteerExpense[]
  documents         VolunteerDocument[]
  activities        VolunteerActivityLog[]
  eventVolunteers   EventVolunteer[]
  projectVolunteers ProjectVolunteer[]

  volunteerAssignments VolunteerAssignment[]
}

model VolunteerProfile {
  id               String    @id @default(uuid())
  volunteerId      String    @unique
  volunteer        Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  profession       String?
  organization     String?
  skills           String?
  languages        String?
  emergencyContact String?
  bloodGroup       String?
  availability     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model VolunteerSkill {
  id              String    @id @default(uuid())
  volunteerId     String
  volunteer       Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  skillName       String
  skillLevel      String?
  experienceYears Int       @default(0)
  verifiedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model VolunteerAvailability {
  id            String    @id @default(uuid())
  volunteerId   String
  volunteer     Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  availableDays String[]
  availableFrom String?
  availableTo   String?
  isAvailable   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VolunteerPerformance {
  id                   String    @id @default(uuid())
  volunteerId          String
  volunteer            Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  totalAssignments     Int       @default(0)
  completedAssignments Int       @default(0)
  attendanceRate       Float     @default(0)
  performanceScore     Float     @default(0)
  rating               Float     @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model VolunteerReward {
  id          String    @id @default(uuid())
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  rewardType  String
  title       String
  description String?
  rewardDate  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model VolunteerCertificate {
  id                String    @id @default(uuid())
  volunteerId       String
  volunteer         Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  certificateType   String
  certificateNumber String    @unique
  issueDate         DateTime  @default(now())
  certificateUrl    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
