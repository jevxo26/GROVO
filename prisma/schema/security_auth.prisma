model LoginAttempt {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  ipAddress String?
  userAgent String?
  success   Boolean  @default(false)
  reason    String?
  createdAt DateTime @default(now())
}

model TrustedDevice {
  id          String    @id @default(uuid())
  userId      String
  deviceId    String
  deviceName  String?
  deviceType  String?
  fingerprint String?
  trustedAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TwoFactorAuthentication {
  id          String    @id @default(uuid())
  userId      String
  method      String
  secret      String?
  isEnabled   Boolean   @default(false)
  verifiedAt  DateTime?
  backupCodes String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model UserBlockHistory {
  id          String    @id @default(uuid())
  userId      String
  blockedBy   String
  reason      String
  blockedAt   DateTime  @default(now())
  unblockedAt DateTime?
  status      String    @default("BLOCKED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model UserBan {
  id         String    @id @default(uuid())
  userId     String
  bannedBy   String
  reason     String
  bannedAt   DateTime  @default(now())
  expiresAt  DateTime?
  liftedAt   DateTime?
  status     String    @default("ACTIVE")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}
