model BeneficiaryNeedAssessment {
  id              String      @id @default(uuid())
  beneficiaryId   String
  beneficiary     Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  assessmentType  String
  requiredSupport String?
  priority        String
  assessedBy      String
  assessmentDate  DateTime
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model DistributionCampaign {
  id               String                 @id @default(uuid())
  campaignId       String
  title            String
  distributionDate DateTime
  location         String?
  status           String                 @default("ACTIVE")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  schedules        DistributionSchedule[]
  records          DistributionRecord[]
}

model DistributionSchedule {
  id                     String             @id @default(uuid())
  distributionCampaignId String
  distributionCampaign   DistributionCampaign @relation(fields: [distributionCampaignId], references: [id], onDelete: Cascade)
  branchId               String
  branch                 Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  distributionCenterId   String
  distributionCenter     DistributionCenter @relation(fields: [distributionCenterId], references: [id], onDelete: Cascade)
  scheduleDate           DateTime
  startTime              String
  endTime                String
  status                 String             @default("ACTIVE")
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

model DistributionCenter {
  id         String                 @id @default(uuid())
  centerName String
  branchId   String
  branch     Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  address    String
  latitude   Float?
  longitude  Float?
  capacity   Int                    @default(0)
  status     String                 @default("ACTIVE")
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  schedules  DistributionSchedule[]
}

model DistributionRecord {
  id                     String                     @id @default(uuid())
  beneficiaryId          String
  beneficiary            Beneficiary                @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  distributionCampaignId String
  distributionCampaign   DistributionCampaign       @relation(fields: [distributionCampaignId], references: [id], onDelete: Cascade)
  packageId              String
  package                ReliefPackage              @relation(fields: [packageId], references: [id], onDelete: Cascade)
  distributedBy          String
  receivedAt             DateTime                   @default(now())
  status                 String                     @default("COMPLETED")
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  items                  DistributionItem[]
  verifications          DistributionVerification[]
  acknowledgements       Acknowledgement[]
  feedbacks              BeneficiaryFeedback[]
}

model DistributionItem {
  id                   String             @id @default(uuid())
  distributionRecordId String
  distributionRecord   DistributionRecord @relation(fields: [distributionRecordId], references: [id], onDelete: Cascade)
  reliefItemId         String
  reliefItem           ReliefItem         @relation(fields: [reliefItemId], references: [id], onDelete: Cascade)
  quantity             Float
  remarks              String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model DistributionVerification {
  id                   String             @id @default(uuid())
  distributionRecordId String
  distributionRecord   DistributionRecord @relation(fields: [distributionRecordId], references: [id], onDelete: Cascade)
  verificationMethod   String
  verifiedBy           String
  verificationTime     DateTime           @default(now())
  status               String             @default("VERIFIED")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Acknowledgement {
  id                   String             @id @default(uuid())
  distributionRecordId String
  distributionRecord   DistributionRecord @relation(fields: [distributionRecordId], references: [id], onDelete: Cascade)
  signature            String?
  photo                String?
  remarks              String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model BeneficiaryFeedback {
  id                   String             @id @default(uuid())
  beneficiaryId        String
  beneficiary          Beneficiary        @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  distributionRecordId String
  distributionRecord   DistributionRecord @relation(fields: [distributionRecordId], references: [id], onDelete: Cascade)
  rating               Int
  feedback             String?
  submittedAt          DateTime           @default(now())
  createdAt            DateTime           @default(now())
}

model FollowUpVisit {
  id            String      @id @default(uuid())
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  visitedBy     String
  visitDate     DateTime
  remarks       String?
  nextVisitDate DateTime?
  status        String      @default("COMPLETED")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model CaseHistory {
  id              String      @id @default(uuid())
  beneficiaryId   String
  beneficiary     Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  caseType        String
  description     String
  assignedOfficer String?
  status          String      @default("OPEN")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
