model ProjectGallery {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  mediaType String
  fileUrl   String
  uploadedBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectUpdate {
  id                 String   @id @default(uuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title              String
  description        String
  progressPercentage Float
  publishedBy        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ProjectTimeline {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  event       String
  description String?
  eventDate   DateTime
  createdBy   String
  createdAt   DateTime @default(now())
}

model FundAllocation {
  id              String   @id @default(uuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  allocatedAmount Float
  allocationDate  DateTime
  approvedBy      String
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fundAllocationHistories FundAllocationHistory[]
}

model ExpenseAttachment {
  id         String         @id @default(uuid())
  expenseId  String
  expense    ProjectExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  fileType   String
  uploadedBy String
  createdAt  DateTime       @default(now())
}

model ProjectReport {
  id                 String   @id @default(uuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportTitle        String
  summary            String?
  beneficiariesCount Int      @default(0)
  totalExpense       Float
  reportFile         String?
  publishedBy        String
  publishedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
}
