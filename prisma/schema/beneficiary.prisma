model Beneficiary {
  id                 String                    @id @default(uuid())
  beneficiaryCode    String                    @unique
  fullName           String
  phone              String?
  nationalId         String?
  dateOfBirth        DateTime?
  gender             String?
  branchId           String
  branch             Branch                    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  divisionId         String?
  districtId         String?
  upazilaId          String?
  unionId            String?
  address            String?
  status             String                    @default("ACTIVE")
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  profile            BeneficiaryProfile?
  familyMembers      FamilyMember[]
  documents          BeneficiaryDocument[]
  needAssessments    BeneficiaryNeedAssessment[]
  qrCodes            BeneficiaryQRCode[]
  distributionRecords DistributionRecord[]
  feedbacks          BeneficiaryFeedback[]
  followUps          FollowUpVisit[]
  caseHistories      CaseHistory[]
  activities         BeneficiaryActivityLog[]
  successStories     SuccessStory[]
}

model BeneficiaryProfile {
  id              String      @id @default(uuid())
  beneficiaryId   String      @unique
  beneficiary     Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  occupation      String?
  monthlyIncome   Float       @default(0)
  familySize      Int         @default(1)
  houseType       String?
  education       String?
  healthCondition String?
  specialNeeds    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model FamilyMember {
  id            String      @id @default(uuid())
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  name          String
  relationship  String
  age           Int
  occupation    String?
  monthlyIncome Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model BeneficiaryCategory {
  id            String   @id @default(uuid())
  categoryName  String
  description   String?
  priorityLevel Int      @default(1)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BeneficiaryDocument {
  id                 String      @id @default(uuid())
  beneficiaryId      String
  beneficiary        Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  documentType       String
  documentNumber     String
  fileUrl            String
  verificationStatus String      @default("PENDING")
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model BeneficiaryQRCode {
  id            String      @id @default(uuid())
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  qrCode        String
  barcode       String?
  verificationUrl String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model BeneficiaryActivityLog {
  id            String      @id @default(uuid())
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  activity      String
  description   String?
  performedBy   String
  createdAt     DateTime    @default(now())
}
