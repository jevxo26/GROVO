model NotificationAutomation {
  id            String   @id @default(uuid())
  triggerEvent  String
  templateId    String?
  targetGroup   String?
  channel       String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkflowAutomation {
  id            String   @id @default(uuid())
  workflowName  String
  triggerEvent  String
  actions       String[]
  conditions    String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AutoTask {
  id           String    @id @default(uuid())
  taskName     String
  taskType     String
  scheduledAt  DateTime
  executedAt   DateTime?
  retryCount   Int       @default(0)
  maxRetries   Int       @default(3)
  payload      String?
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Reminder {
  id           String   @id @default(uuid())
  userId       String
  title        String
  message      String?
  reminderDate DateTime
  reminderType String
  isRecurring  Boolean  @default(false)
  frequency    String?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SmartScheduler {
  id             String   @id @default(uuid())
  scheduleName   String
  scheduleType   String
  cronExpression String?
  startDate      DateTime
  endDate        DateTime?
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  payload        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RouteOptimization {
  id              String   @id @default(uuid())
  optimizationType String
  startLocation   String
  endLocation     String
  waypoints       String[]
  optimizedRoute  String?
  distanceKm      Float    @default(0)
  durationMinutes Float    @default(0)
  createdAt       DateTime @default(now())
}

model AutomationLog {
  id             String   @id @default(uuid())
  automationType String
  triggerEvent   String
  action         String
  entityType     String?
  entityId       String?
  status         String   @default("SUCCESS")
  errorMessage   String?
  executedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
}
