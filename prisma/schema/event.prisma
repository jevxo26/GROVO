model Event {
  id                   String              @id @default(uuid())
  eventCode            String              @unique
  title                String
  slug                 String              @unique
  categoryId           String
  category             EventCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  description          String?
  banner               String?
  thumbnail            String?
  eventType            String
  branchId             String
  branch               Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  venue                String
  startDate            DateTime
  endDate              DateTime
  registrationRequired Boolean             @default(false)
  maxParticipants      Int                 @default(0)
  status               String              @default("ACTIVE")
  createdBy            String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  registrations        EventRegistration[]
  attendances          EventAttendance[]
  speakers             EventSpeaker[]
  volunteers           EventVolunteer[]
  schedules            EventSchedule[]
  galleries            EventGallery[]
}

model EventCategory {
  id          String   @id @default(uuid())
  name        String
  icon        String?
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
}

model EventRegistration {
  id                 String   @id @default(uuid())
  eventId            String
  event              Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId             String
  registrationNumber String   @unique
  registrationDate   DateTime @default(now())
  status             String   @default("CONFIRMED")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model EventAttendance {
  id               String    @id @default(uuid())
  eventId          String
  event            Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId           String
  checkInTime      DateTime?
  checkOutTime     DateTime?
  attendanceStatus String    @default("PRESENT")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model EventSpeaker {
  id           String         @id @default(uuid())
  eventId      String
  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  designation  String?
  organization String?
  photo        String?
  bio          String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     EventSession[]
}

model EventVolunteer {
  id           String    @id @default(uuid())
  eventId      String
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  volunteerId  String
  volunteer    Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  role         String?
  assignedBy   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model EventSchedule {
  id          String         @id @default(uuid())
  eventId     String
  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title       String
  startTime   DateTime
  endTime     DateTime
  location    String?
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sessions    EventSession[]
}

model EventSession {
  id           String        @id @default(uuid())
  scheduleId   String
  schedule     EventSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  sessionTitle String
  speakerId    String?
  speaker      EventSpeaker? @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  duration     Int
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model EventGallery {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  albumId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
