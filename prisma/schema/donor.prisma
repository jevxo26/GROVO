model Donor {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  donorCode         String             @unique
  donorType         String
  membershipId      String?
  registrationDate  DateTime           @default(now())
  status            String             @default("ACTIVE")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  individualProfile IndividualDonor?
  corporateProfile  CorporateDonor?
  subscriptions     DonorSubscription[]
  commitments       DonationCommitment[]
  wallet            DonorWallet?
  certificates      DonorCertificate[]
  badges            DonorBadge[]
  activities        DonorActivity[]
  preference        DonorPreference?
  donations         Donation[]
  schedules         DonationSchedule[]
}

model IndividualDonor {
  id                String   @id @default(uuid())
  donorId           String   @unique
  donor             Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  profession        String?
  organization      String?
  monthlyCommitment Float    @default(0)
  preferredCampaign String?
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CorporateDonor {
  id                    String              @id @default(uuid())
  donorId               String              @unique
  donor                 Donor               @relation(fields: [donorId], references: [id], onDelete: Cascade)
  companyName           String
  companyRegistrationNo String?
  tradeLicense          String?
  contactPerson         String?
  designation           String?
  website               String?
  logo                  String?
  monthlyCommitment     Float               @default(0)
  status                String              @default("ACTIVE")
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  donorOrganizations    DonorOrganization[]
}

model DonorOrganization {
  id               String         @id @default(uuid())
  corporateDonorId String
  corporateDonor   CorporateDonor @relation(fields: [corporateDonorId], references: [id], onDelete: Cascade)
  industry         String?
  companySize      String?
  employeeCount    Int            @default(0)
  address          String?
  city             String?
  country          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model DonorPreference {
  id                String   @id @default(uuid())
  donorId           String   @unique
  donor             Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  preferredCategory String?
  preferredCampaign String?
  anonymousDonation Boolean  @default(false)
  emailNotification Boolean  @default(true)
  smsNotification   Boolean  @default(true)
  pushNotification  Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
