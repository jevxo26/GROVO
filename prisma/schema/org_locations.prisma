model Division {
  id               String            @id @default(uuid())
  name             String            @unique
  code             String            @unique
  countryId        String
  status           String            @default("ACTIVE")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  districts        District[]
  branches         Branch[]
  areaAssignments  AreaAssignment[]
  coordinatorRoles CoordinatorRole[]
  userAddresses    UserAddress[]
}

model District {
  id               String            @id @default(uuid())
  divisionId       String
  division         Division          @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  name             String
  code             String            @unique
  status           String            @default("ACTIVE")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  upazilas         Upazila[]
  branches         Branch[]
  areaAssignments  AreaAssignment[]
  coordinatorRoles CoordinatorRole[]
  userAddresses    UserAddress[]
}

model Upazila {
  id               String            @id @default(uuid())
  districtId       String
  district         District          @relation(fields: [districtId], references: [id], onDelete: Cascade)
  name             String
  code             String            @unique
  status           String            @default("ACTIVE")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  unions           Union[]
  branches         Branch[]
  areaAssignments  AreaAssignment[]
  coordinatorRoles CoordinatorRole[]
  userAddresses    UserAddress[]
}

model Union {
  id               String            @id @default(uuid())
  upazilaId        String
  upazila          Upazila           @relation(fields: [upazilaId], references: [id], onDelete: Cascade)
  name             String
  code             String            @unique
  status           String            @default("ACTIVE")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  branches         Branch[]
  areaAssignments  AreaAssignment[]
  coordinatorRoles CoordinatorRole[]
  userAddresses    UserAddress[]
}